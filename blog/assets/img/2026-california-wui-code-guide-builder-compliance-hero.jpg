      gtag('config', 'G-T8N3TW4VNH', { 'send_page_view': false });

      const gaScript = document.createElement('script');
      gaScript.async = true;
      gaScript.src = 'https://www.googletagmanager.com/gtag/js?id=G-T8N3TW4VNH';
      document.body.appendChild(gaScript);

      gaScript.onload = () => { gtag('event', 'page_view'); };
    }

    setTimeout(() => {
      if ('requestIdleCallback' in window) {
        requestIdleCallback(loadGTM, { timeout: 3000 });
      } else {
        loadGTM();
      }
    }, 5000);
  </script> </body> </html>