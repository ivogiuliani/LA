<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.myvilla.daily-publish</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>/Users/ivogiuliani/Code/myvilla-la/_system/scripts/daily_publish.sh</string>
    </array>

    <!-- STRATEGIA POLL-BASED (come io.giuliani.fallingknife).
         Poll ogni 30 min. Lo script è un near-instant no-op finché
         non sono le 08:00 (TARGET_HOUR) e finché la pipeline di oggi
         non è già stata completata (.guard via log).

         Perché NON StartCalendarInterval: macOS NON fa catch-up
         affidabile dei calendar-interval persi durante lo sleep del
         Mac. StartInterval invece esegue l'intervallo perso APPENA
         il Mac si sveglia → robusto al coperchio chiuso alle 08:00. -->
    <key>StartInterval</key>
    <integer>1800</integer>

    <!-- Esegui anche al login/load per un catch-up immediato. -->
    <key>RunAtLoad</key>
    <true/>

    <!-- Working directory del progetto -->
    <key>WorkingDirectory</key>
    <string>/Users/ivogiuliani/Code/myvilla-la</string>

    <!-- Log su file per i casi di crash precoci (prima che lo script
         apra il proprio log) -->
    <key>StandardOutPath</key>
    <string>/Users/ivogiuliani/Code/myvilla-la/_system/logs/launchd_daily_publish.out.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/ivogiuliani/Code/myvilla-la/_system/logs/launchd_daily_publish.err.log</string>

    <!-- Path per python3 e tool comuni -->
    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/usr/local/bin:/opt/homebrew/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
    </dict>

    <!-- Non riavviare in loop se crasha (esce con codice non-zero):
         meglio fallire una volta e basta che spammare retry -->
    <key>KeepAlive</key>
    <false/>
</dict>
</plist>
