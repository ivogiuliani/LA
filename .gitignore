# Secrets — never commit
.env
.env.*
*.env
secrets/

# Drafts and generated artifacts
# _drafts/social e img/social/evergreen viaggiano in GIT dal 2026-07-02:
# il pannello condiviso sul server (content.myvilla.la) deve vedere le
# proposte social/evergreen e le 3 opzioni immagine (pruning a 7 giorni
# in generate_evergreen.py). Il resto di _drafts (journal, email_replies)
# resta locale: bozze articolo e risposte stampa NON vanno nel repo
# pubblico.
_drafts/*
!_drafts/social/
_archive/
# Cache derivata dei follow-up: si rigenera dal send_log.jsonl (fonte di
# verità). Era TRACCIATA e in JSON → conflitti di rebase irrisolvibili quando
# i due rail la modificavano in parallelo (causa della doppia digest). Locale
# e per-rail: niente più conflitti.
_system/outreach/contact_ledger.json
_system/history/
_system/radar/reports/*.json
_system/radar/reports/*.html
_system/radar/reports/*.md
# ...eccetto l'estratto sanitizzato per il pannello condiviso: solo la
# sezione viral (post pubblici + bozza risposta), niente contatti stampa.
!_system/radar/reports/*.panel.json
# _system/social/posts/ è TRACCIATO dal 2026-07-02: la coda "Approva →
# coda" fatta dalla SMM sul server deve arrivare al publisher delle 8:00
# sul Mac (e viceversa). Contenuti pubblici, nessun dato sensibile.
_system/content_system.log

# Python
__pycache__/
*.pyc
*.pyo

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Editor
.vscode/
.idea/
*.swp

# Claude Code local config (not part of the site)
.claude/

# macOS drag-source artifacts (no purpose on a web server)
*.textClipping
vid.zip

# Cache giornaliera del model resolver (rigenerata ad ogni run, per-macchina)
_system/config/.model_cache.json
_system/social/viral/_raw_latest.json

# Log del pannello (servizio sempre attivo) — non versionare
_system/logs/panel.log
