    // Mobile menu - lazy initialization to avoid forced reflows
    let menuState = null;

    function getMenuState() {
      if (!menuState) {
        const btn = document.getElementById('mobile-menu-button');
        const menu = document.getElementById('mobile-menu');
        if (btn && menu) {
          menuState = { btn, menu, icons: btn.querySelectorAll('svg'), open: false };
        }
      }
      return menuState;
    }

    function toggleMenu() {
      const s = getMenuState();
      if (!s) return;
      s.open = !s.open;
      s.menu.classList.toggle('hidden', !s.open);
      s.btn.setAttribute('aria-expanded', String(s.open));
      if (s.icons[0]) s.icons[0].classList.toggle('hidden', s.open);
      if (s.icons[1]) s.icons[1].classList.toggle('hidden', !s.open);
    }

    document.addEventListener('click', (e) => {
      const s = getMenuState();
      if (!s) return;
      if (s.btn.contains(e.target)) { toggleMenu(); return; }
      if (s.open && !s.menu.contains(e.target)) toggleMenu();
    }, { passive: true });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && menuState?.open) toggleMenu();
    });
  </script> <!-- Google Analytics - Deferred for performance --> <script type="module">
    function loadGTM() {
