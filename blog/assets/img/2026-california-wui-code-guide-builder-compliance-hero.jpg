Call (858) 290-1842
</a> </div> </div> </section> <script>
    // Estimate form submission handler
    const estimateForm = document.getElementById('estimate-form');
    if (estimateForm) {
      estimateForm.addEventListener('submit', async (e) => {
        e.preventDefault();

        const formElement = e.target;
        const submitBtn = document.getElementById('estimate-submit-btn');
        const formMessage = document.getElementById('estimate-message');

        if (submitBtn) {
          submitBtn.disabled = true;
          submitBtn.textContent = 'Sending...';
        }

        // Collect form data
        const data = new FormData(formElement);
        const payload = {
          name: data.get('fullName'),
          phone: data.get('phoneNumber'),
          email: data.get('emailAddress'),
          message: `Project Type: ${data.get('projectType')}\n\nDetails: ${data.get('projectDetails') || 'Not provided'}`,
          source: 'pbb_estimate_form'
        };

        try {
          const response = await fetch('/api/lead', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload)
          });

          await response.json();

          if (formMessage) {
            formMessage.classList.remove('hidden');
            if (response.ok) {
              formMessage.className = 'p-3 rounded-md text-center text-sm bg-green-100 text-green-800';
              formMessage.textContent = 'Thank you! We will contact you within 24 hours with your free estimate.';
              formElement.reset();
            } else {
              formMessage.className = 'p-3 rounded-md text-center text-sm bg-red-100 text-red-800';
              formMessage.textContent = 'Sorry, there was an error. Please call us at (858) 290-1842.';
            }
          }
        } catch (error) {
          console.error('Error submitting form:', error);
          if (formMessage) {
            formMessage.classList.remove('hidden');
            formMessage.className = 'p-3 rounded-md text-center text-sm bg-red-100 text-red-800';
            formMessage.textContent = 'Sorry, there was an error. Please call us at (858) 290-1842.';
          }
        } finally {
          if (submitBtn) {
            submitBtn.disabled = false;
            submitBtn.textContent = 'Get Free Estimate';
          }
        }
      });
    }
  </script>  </main> <footer class="bg-gray-900 text-white" data-astro-cid-37fxchfa> <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12" data-astro-cid-37fxchfa> <div class="grid md:grid-cols-4 gap-8" data-astro-cid-37fxchfa> <div class="md:col-span-2" data-astro-cid-37fxchfa> <h3 class="text-xl font-bold mb-4" data-astro-cid-37fxchfa>Pacific Beach Builder</h3> <p class="text-gray-300 mb-4" data-astro-cid-37fxchfa>
